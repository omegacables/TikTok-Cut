# Gemini を使う場合のみ設定（未設定でも heuristic fallback で動作する）
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 使用する LLM プロバイダ: gemini | openai | claude | heuristic
LLM_PROVIDER=gemini
# モデル（開発中の品質⇄コスト精査用に差し替え可）
LLM_MODEL=gemini-3.5-pro

# 他プロバイダを使う場合
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# faster-whisper 設定
WHISPER_MODEL=small          # tiny / base / small / medium / large-v3
WHISPER_DEVICE=auto          # auto / cpu / cuda
WHISPER_LANGUAGE=            # 空=自動判定 / ja で日本語固定
